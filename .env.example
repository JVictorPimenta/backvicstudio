PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=seu_jwt_secreto
ADMIN_EMAILS=
# Formato da connection string: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@db.example.supabase.co:5432/postgres
# Alternativamente, variáveis separadas (opcional)
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_HOST=db.example.supabase.co
DB_PORT=5432
DB_NAME=postgres
# Controle de logging do Sequelize
DB_LOGGING=false
# (Opcional) Credenciais do Supabase se você usar o client no backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=public-or-service-role-key

# Observação: se a senha contém caracteres especiais (por exemplo: @, :, /)
# você precisa URL-encodificá-los na `DATABASE_URL`.
# Exemplo: senha 'S3nh@' -> 'S3nh%40'
