PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=seu_jwt_secreto
ADMIN_EMAILS=admin@gmail.com
# Formato da connection string: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@db.example.supabase.co:5432/postgres
# Alternativamente, variáveis separadas (opcional)
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=db.example.supabase.co
DB_PORT=3306
DB_NAME=im
# Controle de logging do Sequelize
DB_LOGGING=false